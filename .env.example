# NextAuth
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# Sentry
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# Email notifikace — Resend (https://resend.com)
# 1. Vytvořte účet na resend.com (free tier: 100 emailů/den)
# 2. Přidejte a ověřte doménu remeslnik.app (Settings → Domains)
# 3. Vygenerujte API klíč (API Keys → Create API Key)
# 4. Přidejte RESEND_API_KEY do Vercel (Settings → Environment Variables)
# Bez tohoto nastavení se submity pouze logují v konzoli
RESEND_API_KEY=""

# Operátorský email — kam chodit notifikace z poptávkového formuláře
OPERATOR_EMAIL="homolkamarek98@gmail.com"

# Concierge MVP — přihlášení řemeslníka (supply form)
# Samostatný Formspree formulář pro řemeslníky
FORMSPREE_SUPPLY_URL=""

# Facebook Pixel — získejte ID v Meta Business Manager > Events Manager
# Bez tohoto nastavení se Pixel nenačte (bezpečné pro lokální vývoj)
NEXT_PUBLIC_FB_PIXEL_ID=""
