# Database (Neon.tech)
DATABASE_URL="postgresql://user:password@host/remeslnik?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@host/remeslnik?sslmode=require"

# NextAuth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Resend (email)
RESEND_API_KEY="re_..."
RESEND_FROM="Řemeslník.app <faktury@remeslnik.app>"

# Cloudflare R2 (file storage)
R2_ACCOUNT_ID="..."
R2_ACCESS_KEY_ID="..."
R2_SECRET_ACCESS_KEY="..."
R2_BUCKET_NAME="remeslnik-uploads"
R2_PUBLIC_URL="https://pub-xxx.r2.dev"

# Sentry
SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
SENTRY_ORG="remeslnik"
SENTRY_PROJECT="remeslnik-app"
NEXT_PUBLIC_SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
